# DocuMind AI backend .dockerignore
# Files/directories excluded from the Docker build context
# Smaller build context = faster builds

# Virtual environment — dependencies are installed fresh in the image
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
dist/
build/
*.egg-info/

# Development files
*.log
backend.log
diagnose.py
check_db.py
test_api.py

# Environment files — never bake secrets into images
.env
.env.*
!.env.example

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
docs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Uploads — these are mounted as volumes at runtime
uploads/

# Node (shouldn't be here but just in case)
node_modules/
