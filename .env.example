# =============================================================================
# DocuMind AI — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in all values marked as REQUIRED.
# NEVER commit .env to version control.
#
#   cp .env.example .env
#
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres           # REQUIRED: change in production
POSTGRES_DB=documind_ai
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DocuMind AI
APP_VERSION=1.0.0
ENVIRONMENT=production               # development | testing | production
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=80                         # nginx external port
HOST=0.0.0.0
PORT=8000

# ── Database (set automatically by compose from POSTGRES_* vars above)
# DATABASE_URL is set by docker-compose.yml from POSTGRES_* vars.
# Only set this manually when running outside Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind_ai

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_UPLOAD_SIZE_MB=50
MAX_REQUEST_SIZE_KB=1024
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_AUTH=10
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_CHAT=30
TRUSTED_PROXIES=172.20.0.0/16       # Docker bridge network CIDR

# ── Email (optional — uses console mock when SMTP_HOST is empty) ───────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@documind.ai
EMAIL_FROM_NAME=DocuMind AI
FRONTEND_URL=http://localhost

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# REQUIRED: Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite
