# DocuMind AI — Frontend Production Environment Variables
# Set these in: Vercel Dashboard → Project Settings → Environment Variables
# Do NOT commit a file with real values.

# REQUIRED — Your Render backend URL (no trailing slash)
VITE_API_BASE_URL=https://documind-backend.onrender.com

# Application metadata
VITE_APP_NAME=DocuMind AI
VITE_APP_VERSION=1.0.0

# Environment identifier (used for conditional debug features)
VITE_ENVIRONMENT=production
